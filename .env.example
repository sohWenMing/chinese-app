# Vercel Token
# Get yours at: https://vercel.com/account/tokens
# Then paste it below (replace this line)
VERCEL_TOKEN=your_vercel_token_here

# Gemini API Key
# Get yours at: https://ai.google.dev/
# Then paste it below (replace this line)
GEMINI_API_KEY=your_gemini_api_key_here

# Family Password
# This is used to protect the app - choose something your family can remember
# Then paste it below (replace this line)
FAMILY_PASSWORD=your_family_password_here
